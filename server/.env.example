# Copy this file to `.env` and fill in the values. NEVER commit the real .env.

# Server
PORT=4000
NODE_ENV=development

# Comma-separated list of origins allowed to call the API (the frontend URL).
# Dev default below works with Vite. In prod set your real domain.
CORS_ORIGIN=http://localhost:5173

# MongoDB Atlas connection string (Atlas > Connect > Drivers).
# Leave blank to run without a database (contact messages won't persist).
MONGODB_URI=

# Anthropic (Claude) — get a key at https://console.anthropic.com
# Leave blank to disable the AI assistant gracefully.
ANTHROPIC_API_KEY=
# Cost-efficient default for a public widget; swap to claude-sonnet-4-6 for higher quality.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# AWS SES — contact-form email notifications. Leave blank to disable.
# AWS credentials come from the host's IAM role in production, or from
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY locally. Only set the three below:
AWS_REGION=
SES_FROM=          # a verified SES sender, e.g. you@yourdomain.com
SES_TO=            # where you want submissions delivered, e.g. sgiraldog@gmail.com
